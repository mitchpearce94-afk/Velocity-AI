# Velocity AI — Environment Variables
# Copy this to .env and fill in your actual keys.
# NEVER commit .env to git.

# Retell AI (voice agent)
RETELL_API_KEY=key_your_retell_api_key_here
RETELL_AGENT_IDS=agent_id_1,agent_id_2
RETELL_REPORT_AGENT_ID=agent_your_report_agent_id

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key_here

# Cal.com (calendar booking)
CAL_API_KEY=cal_live_your_calcom_key_here
CAL_USERNAME=your-cal-username
CAL_EVENT_SLUG=discovery-call

# Google Places (lead research)
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Twilio (outbound calling)
TWILIO_FROM_NUMBER=+61XXXXXXXXX

# Stripe (payments)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Internal
MITCHELL_EMAIL=your@email.com
