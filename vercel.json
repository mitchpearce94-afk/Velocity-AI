{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/brand/:path*", "destination": "/brand/:path*" },
    { "source": "/(.*)", "destination": "/website/index.html" }
  ],
  "headers": [
    {
      "source": "/brand/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
